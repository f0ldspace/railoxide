#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
bundle_root="$repo_root/target/macos"
app_name="RailOxide"
app_bundle="$bundle_root/$app_name.app"
dmg_staging_dir="$bundle_root/dmg"
dmg_path="$bundle_root/$app_name.dmg"
contents_dir="$app_bundle/Contents"
macos_dir="$contents_dir/MacOS"
resources_dir="$contents_dir/Resources"
binary_src="$repo_root/target/release/wallet"
binary_dst="$macos_dir/$app_name"
plist_src="$repo_root/bins/wallet/packaging/macos/Info.plist"
icon_src="$repo_root/bins/wallet/packaging/icons/macos/RailOxide.icns"
codesign_identity="${CODESIGN_IDENTITY:--}"
cargo_features="${CARGO_FEATURES-hardware,gpui/runtime_shaders}"
cargo_bin="${CARGO_BIN:-cargo}"
cargo_toolchain="${CARGO_TOOLCHAIN:-}"

require_tool() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'missing required tool: %s\n' "$1" >&2
    exit 1
  fi
}

require_tool "$cargo_bin"
require_tool codesign
require_tool ditto
require_tool hdiutil
require_tool plutil

if [[ "$(uname -s)" != "Darwin" ]]; then
  printf 'macOS app packaging requires macOS\n' >&2
  exit 1
fi

if [[ ! -f "$plist_src" ]]; then
  printf 'missing Info.plist: %s\n' "$plist_src" >&2
  exit 1
fi

if [[ ! -f "$icon_src" ]]; then
  printf 'missing app icon: %s\n' "$icon_src" >&2
  exit 1
fi

cargo_command=("$cargo_bin")
if [[ -n "$cargo_toolchain" ]]; then
  cargo_command+=("+$cargo_toolchain")
fi

if [[ -n "$cargo_features" ]]; then
  "${cargo_command[@]}" build --release -p wallet --features "$cargo_features"
else
  "${cargo_command[@]}" build --release -p wallet
fi

rm -rf "$app_bundle"
mkdir -p "$macos_dir" "$resources_dir"

cp "$binary_src" "$binary_dst"
cp "$plist_src" "$contents_dir/Info.plist"
cp "$icon_src" "$resources_dir/RailOxide.icns"
chmod 755 "$binary_dst"

plutil -lint "$contents_dir/Info.plist"
codesign --force --deep --sign "$codesign_identity" "$app_bundle"
codesign --verify --deep --strict --verbose=2 "$app_bundle"

rm -rf "$dmg_staging_dir" "$dmg_path"
mkdir -p "$dmg_staging_dir"
ditto "$app_bundle" "$dmg_staging_dir/$app_name.app"
ln -s /Applications "$dmg_staging_dir/Applications"

hdiutil create \
  -volname "$app_name" \
  -srcfolder "$dmg_staging_dir" \
  -ov \
  -format UDZO \
  "$dmg_path"
hdiutil verify "$dmg_path"

printf 'packaged %s\n' "$app_bundle"
printf 'packaged %s\n' "$dmg_path"
